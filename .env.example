# Qwen Image Edit API test environment variables
# Copy this file to test.env or .env and fill in actual values

# RunPod API key (required)
runpod_API_KEY=your-runpod-api-key-here

# Qwen Image Edit endpoint ID (required)
qwen_image_edit=your-endpoint-id-here

# Test image URL (optional, can also use --image-url in test_api.py)
# TEST_IMAGE_URL=https://example.com/your-test-image.jpg

# --- S3/Network Volume config (for reference) ---
# url=https://s3api-<region>.runpod.io/
# region=eu-ro-1
# access_key_id=your-access-key
# bucket_name=your-bucket-name
# secret_access_key=your-secret-key